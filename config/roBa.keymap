        MAC_IPA(m_v_8_1, N0, N0, N0, N0) MAC_IPA(m_v_8_2, N0, N0, N0, N0) MAC_IPA(m_v_8_5, N0, N0, N0, N0)
        MAC_IPA(m_v_8_6, N0, N0, N0, N0) MAC_IPA(m_v_8_7, N0, N0, N0, N0) MAC_IPA(m_v_8_10, N0, N0, N0, N0)
