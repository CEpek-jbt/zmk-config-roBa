        combo_MGB { timeout-ms = <300>; key-positions = <30 14 26>; bindings = <&mac_ipa_0260_0361_0253>; };
    };

    macros {
        // --- 基礎となる送信関数 (16進数入力をシミュレート) ---
        // OS側の設定(Unicode Hex Input等)に合わせて調整が必要ですが、
        // 以下の定義は「1文字ずつ送信する」ための基本構造です。
        #define SEND_IPA(U1, U2, U3, U4) \
            bindings = <&macro_tap &kp U1 &kp U2 &kp U3 &kp U4>;

        // --- Layer 7: Nasal ---
        m_nsa_bil_vl: m_nsa_bil_vl { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; 
            bindings = <&macro_tap &kp M &kp U+0325>; }; // m̥
        m_nsa_bil_vd: m_nsa_bil_vd { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; 
            bindings = <&macro_tap &kp M>; }; // m
        m_nsa_lab_vl: m_nsa_lab_vl { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; 
            bindings = <&macro_tap &kp U+0271 &kp U+030A>; }; // ɱ̊
        m_nsa_lab_vd: m_nsa_lab_vd { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; 
            bindings = <&macro_tap &kp U+0271>; }; // ɱ
        m_nsa_den_vl: m_nsa_den_vl { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; 
            bindings = <&macro_tap &kp N &kp U+032A &kp U+030A>; }; // n̪̊
        m_nsa_den_vd: m_nsa_den_vd { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; 
            bindings = <&macro_tap &kp N &kp U+032A>; }; // n̪
        m_nsa_alv_vl: m_nsa_alv_vl { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; 
            bindings = <&macro_tap &kp N &kp U+0325>; }; // n̥
        m_nsa_alv_vd: m_nsa_alv_vd { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; 
            bindings = <&macro_tap &kp N>; }; // n
        m_nsa_palv_vl: m_nsa_palv_vl { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; 
            bindings = <&macro_tap &kp N &kp U+0320 &kp U+030A>; }; // n̠̊
        m_nsa_palv_vd: m_nsa_palv_vd { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; 
            bindings = <&macro_tap &kp N &kp U+0320>; }; // n̠
        m_nsa_ret_vl: m_nsa_ret_vl { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; 
            bindings = <&macro_tap &kp U+0273 &kp U+030A>; }; // ɳ̊
        m_nsa_ret_vd: m_nsa_ret_vd { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; 
            bindings = <&macro_tap &kp U+0273>; }; // ɳ
        m_nsa_pal_vl: m_nsa_pal_vl { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; 
            bindings = <&macro_tap &kp U+0272 &kp U+030A>; }; // ɲ̊
        m_nsa_pal_vd: m_nsa_pal_vd { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; 
            bindings = <&macro_tap &kp U+0272>; }; // ɲ
        m_nsa_vel_vl: m_nsa_vel_vl { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; 
            bindings = <&macro_tap &kp U+014B &kp U+030A>; }; // ŋ̊
        m_nsa_vel_vd: m_nsa_vel_vd { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; 
            bindings = <&macro_tap &kp U+014B>; }; // ŋ
        m_nsa_uvu_vl: m_nsa_uvu_vl { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; 
            bindings = <&macro_tap &kp U+0274 &kp U+0325>; }; // ɴ̥
        m_nsa_uvu_vd: m_nsa_uvu_vd { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; 
            bindings = <&macro_tap &kp U+0274>; }; // ɴ

        // --- Layer 10: Non-sibilant Affricate (合字対応) ---
        m_nsa_bil_vl: m_nsa_bil_vl { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; 
            bindings = <&macro_tap &kp P &kp U+0361 &kp U+0278>; }; // p͡ɸ
        m_nsa_bil_vd: m_nsa_bil_vd { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; 
            bindings = <&macro_tap &kp B &kp U+0361 &kp U+03B2>; }; // b͡β
        m_nsa_lab_vl: m_nsa_lab_vl { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; 
            bindings = <&macro_tap &kp P &kp U+032A &kp U+0361 &kp F>; }; // p̪͡f
        m_nsa_lab_vd: m_nsa_lab_vd { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; 
            bindings = <&macro_tap &kp B &kp U+032A &kp U+0361 &kp V>; }; // b̪͡v
        m_nsa_den_vl: m_nsa_den_vl { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; 
            bindings = <&macro_tap &kp T &kp U+032A &kp U+0361 &kp U+03B8>; }; // t̪͡θ
        m_nsa_den_vd: m_nsa_den_vd { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; 
            bindings = <&macro_tap &kp D &kp U+032A &kp U+0361 &kp U+00F0>; }; // d̪͡ð
        m_nsa_alv_vl: m_nsa_alv_vl { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; 
            bindings = <&macro_tap &kp T &kp U+0361 &kp U+0279 &kp U+031D &kp U+030A>; }; // t͡ɹ̝̊
        m_nsa_alv_vd: m_nsa_alv_vd { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; 
            bindings = <&macro_tap &kp D &kp U+0361 &kp U+0279 &kp U+031D>; }; // d͡ɹ̝
        m_nsa_palv_vl: m_nsa_palv_vl { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; 
            bindings = <&macro_tap &kp T &kp U+0320 &kp U+0361 &kp U+0279 &kp U+0320 &kp U+031D &kp U+030A>; }; // t̠͡ɹ̠̊˔
        m_nsa_palv_vd: m_nsa_palv_vd { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; 
            bindings = <&macro_tap &kp D &kp U+0320 &kp U+0361 &kp U+0279 &kp U+0320 &kp U+031D>; }; // d̠͡ɹ̠˔
        m_nsa_ret_vl: m_nsa_ret_vl { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; 
            bindings = <&macro_tap &kp U+0288 &kp U+0361 &kp U+027B &kp U+031D &kp U+030A>; }; // ʈ͡ɻ̊˔
        m_nsa_ret_vd: m_nsa_ret_vd { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; 
            bindings = <&macro_tap &kp U+0256 &kp U+0361 &kp U+027B &kp U+031D>; }; // ɖ͡ɻ̝
