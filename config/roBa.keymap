    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
                &kp Q      &kp W      &kp E      &kp R      &kp T                         &kp Y      &kp U      &kp I      &kp O      &kp P
                &kp A      &kp S      &kp D      &kp F      &kp G                         &kp H      &kp J      &kp K      &kp L      &kp SEMI
                &kp Z      &kp X      &kp C      &kp V      &kp B      &kp LBKT &kp RBKT &kp N      &kp M      &kp COMMA  &kp DOT    &kp FSLH
                                      &kp LCTRL  &kp LALT   &kp SPACE                     &kp ENTER  &kp RALT   &kp RCTRL
            >;
        };

        unused_1 { bindings = <TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR>; };
        unused_2 { bindings = <TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR>; };
        unused_3 { bindings = <TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR>; };

        mouse_layer {
            bindings = <
                TR TR TR TR TR TR TR TR TR TR
                TR TR TR TR TR TR TR TR TR TR
                TR TR TR TR TR TR TR TR TR TR TR TR
                TR TR TR TR TR TR
            >;
        };

        scroll_layer {
            bindings = <
                TR TR TR TR TR TR TR TR TR TR
                TR TR TR TR TR TR TR TR TR TR
                TR TR TR TR TR TR TR TR TR TR TR TR
                TR TR TR TR TR TR
            >;
        };

        num_layer {
            bindings = <
                &kp N1 &kp N2 &kp N3 &kp N4 &kp N5   &kp N6 &kp N7 &kp N8 &kp N9 &kp N0
                TR TR TR TR TR TR TR TR TR TR
                TR TR TR TR TR TR TR TR TR TR TR TR
                TR TR TR TR TR TR
            >;
        };

        nasal_layer { bindings = <TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR>; };
        plosive_layer { bindings = <TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR>; };
        nsfricative_layer { bindings = <TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR>; };
        nsaffricate_layer { bindings = <TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR>; };
        sfricative_layer { bindings = <TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR>; };
        saffricate_layer { bindings = <TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR>; };
        lfricative_layer { bindings = <TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR>; };
        laffricate_layer { bindings = <TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR>; };
        approximant_layer { bindings = <TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR>; };
        lapproximant_layer { bindings = <TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR>; };
        tap_layer { bindings = <TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR>; };
        ltap_layer { bindings = <TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR>; };
        trill_layer { bindings = <TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR>; };
        implo_layer { bindings = <TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR>; };
        lat_implo_layer { bindings = <TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR TR>; };
    };
};
