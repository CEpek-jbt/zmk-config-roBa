        m_lim_den_vl: m_lim_den_vl { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; bindings = <&macro_tap &kp U+01C1 &kp U+0332>; }; // ǁ̠ (参考値)

        // --- Layer 8: Close (狭母音) ---
        v_cl_fr_un: v_cl_fr_un { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; bindings = <&macro_tap &kp I>; }; // i
