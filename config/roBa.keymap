        m_tr_ret_vd: m_tr_ret_vd { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; bindings = <&macro_tap &kp R &kp U+0361 &kp U+027D>; }; // r͡ɽ
        m_tr_uvu_vl: m_tr_uvu_vl { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; bindings = <&macro_tap &kp U+0280 &kp U+0325>; }; // ʀ̥
        m_tr_uvu_vd: m_tr_uvu_vd { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; bindings = <&macro_tap &kp U+0280>; }; // ʀ
        m_tr_epi_vl: m_tr_epi_vl { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; bindings = <&macro_tap &kp U+029C &kp U+030C>; }; // ʜ̌
        m_tr_epi_vd: m_tr_epi_vd { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; bindings = <&macro_tap &kp U+02A2>; }; // ʢ

        // --- Layer 20: Implosive (吸着音 / 入破音) ---
        m_im_bil_vl: m_im_bil_vl { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; bindings = <&macro_tap &kp U+0298>; }; // ʘ
        m_im_bil_vd: m_im_bil_vd { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; bindings = <&macro_tap &kp U+0253>; }; // ɓ
        m_im_den_vl: m_im_den_vl { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; bindings = <&macro_tap &kp U+01C0>; }; // ǀ
        m_im_alv_vl: m_im_alv_vl { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; bindings = <&macro_tap &kp U+01C3>; }; // ǃ
        m_im_alv_vd: m_im_alv_vd { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; bindings = <&macro_tap &kp U+0257>; }; // ɗ
        m_im_ret_vl: m_im_ret_vl { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; bindings = <&macro_tap &kp U+203C>; }; // ‼︎
        m_im_ret_vd: m_im_ret_vd { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; bindings = <&macro_tap &kp U+1DA1>; }; // ᶑ
        m_im_pal_vl: m_im_pal_vl { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; bindings = <&macro_tap &kp U+01C2>; }; // ǂ
        m_im_pal_vd: m_im_pal_vd { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; bindings = <&macro_tap &kp U+0284>; }; // ʄ
        m_im_vel_vl: m_im_vel_vl { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; bindings = <&macro_tap &kp U+01C1>; }; // ǁ
        m_im_vel_vd: m_im_vel_vd { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; bindings = <&macro_tap &kp U+0260>; }; // ɠ
        m_im_uvu_vd: m_im_uvu_vd { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; bindings = <&macro_tap &kp U+029B>; }; // ʛ

