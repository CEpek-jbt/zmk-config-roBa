        m_ltap_alv_vd: m_ltap_alv_vd { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; bindings = <&macro_tap &kp U+027A>; }; // ɺ
        m_ltap_ret_vl: m_ltap_ret_vl { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; bindings = <&macro_tap &kp U+026D &kp U+0306 &kp U+030A>; }; // ɭ̆ ̥
        m_ltap_ret_vd: m_ltap_ret_vd { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; bindings = <&macro_tap &kp U+026D &kp U+0306>; }; // ɭ̆
        m_ltap_pal_vd: m_ltap_pal_vd { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; bindings = <&macro_tap &kp U+028E &kp U+0306>; }; // ʎ̆
        m_ltap_vel_vd: m_ltap_vel_vd { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; bindings = <&macro_tap &kp U+029F &kp U+0306>; }; // ʟ̆

        // --- Layer 19: Trill (ふるえ音) ---
        m_tr_bil_vl: m_tr_bil_vl { compatible = "zmk,behavior-macro"; #binding-cells = <0>; wait-ms = <1>; tap-ms = <1>; bindings = <&macro_tap &kp U+0299 &kp U+0325>; }; // ʙ̥
